<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Custom Keyboard 验证入口"
            android:textColor="#111827"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="每个宿主场景都拆成独立 Activity，便于单独验证窗口层级、外部点击、返回键、底部顶起和生命周期切换。"
            android:textColor="#4B5563"
            android:textSize="14sp" />

        <Button
            android:id="@+id/openActivityScenarioButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Activity 宿主验证" />

        <Button
            android:id="@+id/openFragmentScenarioButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Fragment 宿主验证" />

        <Button
            android:id="@+id/openMixedFragmentScenarioButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Fragment 混合输入验证" />

        <Button
            android:id="@+id/openDialogScenarioButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="DialogFragment 宿主验证" />

        <Button
            android:id="@+id/openCustomDialogScenarioButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="自定义 Dialog 宿主验证" />

        <Button
            android:id="@+id/openBottomSheetScenarioButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="BottomSheet 宿主验证" />

    </LinearLayout>
</ScrollView>
