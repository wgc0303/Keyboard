<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/white"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Custom Keyboard Demo"
            android:textColor="#111827"
            android:textSize="22sp"
            android:textStyle="bold" />

        <cn.wgc.keyboard.CustomKeyboardEditText
            android:id="@+id/numberInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="22dp"
            android:backgroundTint="#CBD5E1"
            android:hint="数字键盘"
            android:paddingHorizontal="12dp"
            android:textSize="16sp"
            app:ck_keyGap="0dp"
            app:ck_keyboardType="number" />

        <cn.wgc.keyboard.CustomKeyboardEditText
            android:id="@+id/idCardInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="18dp"
            android:backgroundTint="#CBD5E1"
            android:hint="身份证键盘"
            android:paddingHorizontal="12dp"
            android:textSize="16sp"
            app:ck_keyGap="0dp"
            app:ck_keyboardType="idCard" />

        <cn.wgc.keyboard.CustomKeyboardEditText
            android:id="@+id/passwordInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="18dp"
            android:backgroundTint="#CBD5E1"
            android:hint="数字密码键盘"
            android:paddingHorizontal="12dp"
            android:textSize="16sp"
            app:ck_keyHeight="54dp"
            app:ck_keyTextColor="#111827"
            app:ck_keyGap="0dp"
            app:ck_randomNumberKeys="true"
            app:ck_keyboardType="numberPassword" />

        <cn.wgc.keyboard.CustomKeyboardEditText
            android:id="@+id/alphaNumberInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="18dp"
            android:backgroundTint="#CBD5E1"
            android:hint="字母数字键盘（禁用点号）"
            android:paddingHorizontal="12dp"
            android:textSize="16sp"
            app:ck_disableDot="true"
            app:ck_disableSpace="true"
            app:ck_alphaInitialMode="letter"
            app:ck_keyGap="0dp"
            app:ck_keyboardType="alphaNumber" />

        <cn.wgc.keyboard.CustomKeyboardEditText
            android:id="@+id/styledNumberInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="18dp"
            android:backgroundTint="#CBD5E1"
            android:hint="自定义颜色数字键盘"
            android:paddingHorizontal="12dp"
            android:textSize="16sp"
            app:ck_dividerColor="#F59E0B"
            app:ck_keyHeight="48dp"
            app:ck_keyTextColor="#7C2D12"
            app:ck_keyboardBackgroundColor="#FFF7ED"
            app:ck_keyboardType="number"
            app:ck_keyGap="0dp" />

        <cn.wgc.keyboard.CustomKeyboardEditText
            android:id="@+id/styledAlphaInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="18dp"
            android:backgroundTint="#CBD5E1"
            android:hint="自定义字母键盘样式"
            android:paddingHorizontal="12dp"
            android:textSize="16sp"
            app:ck_alphaInitialMode="letter"
            app:ck_dividerColor="#93C5FD"
            app:ck_keyHeight="50dp"
            app:ck_keyTextColor="#1D4ED8"
            app:ck_keyboardBackgroundColor="#EFF6FF"
            app:ck_letterRowBackgroundColor="#DBEAFE"
            app:ck_keyboardType="alphaNumber"
            app:ck_keyGap="0dp" />

        <cn.wgc.keyboard.CustomKeyboardEditText
            android:id="@+id/spacedStyleInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="18dp"
            android:backgroundTint="#CBD5E1"
            android:hint="自定义间距键盘样式"
            android:paddingHorizontal="12dp"
            android:textSize="16sp"
            app:ck_keyGap="6dp"
            app:ck_keyHeight="52dp"
            app:ck_keyTextColor="#064E3B"
            app:ck_keyboardType="number"
            app:ck_panelPaddingWhenSpaced="8dp"
            app:ck_spacedKeyboardBackgroundColor="#ECFDF5" />

        <cn.wgc.keyboard.CustomKeyboardEditText
            android:id="@+id/iconNumberInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="18dp"
            android:backgroundTint="#CBD5E1"
            android:hint="自定义收起/删除图标数字键盘"
            android:paddingHorizontal="12dp"
            android:textSize="16sp"
            app:ck_deleteIcon="@drawable/ic_demo_delete"
            app:ck_hideKeyboardIcon="@drawable/ic_demo_hide_keyboard"
            app:ck_keyGap="0dp"
            app:ck_keyboardType="number" />

        <cn.wgc.keyboard.CustomKeyboardEditText
            android:id="@+id/iconPasswordInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="18dp"
            android:backgroundTint="#CBD5E1"
            android:hint="自定义显隐/删除图标密码键盘"
            android:paddingHorizontal="12dp"
            android:textSize="16sp"
            app:ck_deleteIcon="@drawable/ic_demo_delete"
            app:ck_invisibleIcon="@drawable/ic_demo_invisible"
            app:ck_keyGap="0dp"
            app:ck_keyboardType="numberPassword"
            app:ck_visibleIcon="@drawable/ic_demo_visible" />

        <cn.wgc.keyboard.CustomKeyboardEditText
            android:id="@+id/iconAlphaInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="18dp"
            android:backgroundTint="#CBD5E1"
            android:hint="自定义Shift/删除图标字母键盘"
            android:paddingHorizontal="12dp"
            android:textSize="16sp"
            app:ck_alphaInitialMode="letter"
            app:ck_deleteIcon="@drawable/ic_demo_delete"
            app:ck_keyGap="0dp"
            app:ck_keyboardType="alphaNumber"
            app:ck_shiftActiveIcon="@drawable/ic_demo_shift_active"
            app:ck_shiftIcon="@drawable/ic_demo_shift" />

        <EditText
            android:id="@+id/systemEditText"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="18dp"
            android:backgroundTint="#CBD5E1"
            android:hint="普通EditText，用于验证系统键盘外部收起"
            android:paddingHorizontal="12dp"
            android:textSize="16sp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="420dp" />

        <cn.wgc.keyboard.CustomKeyboardEditText
            android:id="@+id/bottomInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:backgroundTint="#CBD5E1"
            android:hint="底部输入框，用于验证遮挡顶起"
            android:paddingHorizontal="12dp"
            android:textSize="16sp"
            app:ck_keyGap="0dp"
            app:ck_keyboardType="alphaNumber" />

    </LinearLayout>
</ScrollView>
